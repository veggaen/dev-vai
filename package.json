{
  "name": "vai",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "dev": "concurrently --kill-others --names runtime,desktop -c cyan,magenta \"pnpm dev:web\" \"node scripts/wait-for-runtime.mjs && node scripts/dev-desktop-or-reuse.mjs\"",
    "dev:desktop:native": "pnpm --filter @vai/desktop dev:tauri",
    "dev:web": "pnpm --filter @vai/runtime dev",
    "dev:desktop": "pnpm --filter @vai/desktop dev",
    "dev:ext": "pnpm --filter @vai/extension dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @vai/desktop build:tauri",
    "app:update": "node scripts/update-desktop-app.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "db:generate": "pnpm --filter @vai/core db:generate",
    "db:migrate": "pnpm --filter @vai/core db:migrate",
    "update": "git pull && pnpm install && pnpm build",
    "nuke": "node scripts/predev.mjs && echo [VAI] All ports cleared",
    "release:dev": "git add -A && git commit && git push origin dev",
    "release:main": "git checkout main && git merge dev --no-ff && git push origin main && git checkout dev",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "vai": "node scripts/vai-server.mjs",
    "vai:start": "node scripts/vai-server.mjs start",
    "vai:stop": "node scripts/vai-server.mjs stop",
    "vai:restart": "node scripts/vai-server.mjs restart",
    "vai:status": "node scripts/vai-server.mjs status",
    "chat:sessions:archive": "node scripts/archive-chat-sessions.mjs",
    "chat:sessions:archive:apply": "node scripts/archive-chat-sessions.mjs --apply",
    "vai:eval": "node scripts/vai-eval.mjs",
    "corpus:lint": "node scripts/build-corpus.mjs lint",
    "corpus:build": "node scripts/build-corpus.mjs build",
    "vai:retrieval:eval": "tsx scripts/vai-retrieval-eval.mjs",
    "vai:humaneval:lite": "node scripts/vai-humaneval-lite.mjs",
    "vai:chat:bench": "node scripts/vai-chat-benchmark.mjs",
    "vai:chat:floor": "node scripts/vai-answer-floor.mjs",
    "vai:scenarios": "node scripts/vai-scenarios-run.mjs",
    "vai:scenarios:live": "node scripts/vai-scenario-bench.mjs",
    "vai:scenarios:list": "node scripts/vai-scenario-bench.mjs --list",
    "vai:chat:smoke": "node scripts/vai-chat-smoke.mjs",
    "vai:chat:smoke:live": "node scripts/vai-chat-smoke.mjs --live",
    "verify:pro-app-chat": "node scripts/verify-pro-app-chat.mjs",
    "verify:chat:five-apps:visual": "node scripts/verify-five-chat-builder-apps-visual.mjs",
    "verify:chat:quality": "node scripts/verify-chat-build-quality.mjs",
    "verify:chat:quality:live": "node scripts/verify-chat-build-quality.mjs --live",
    "verify:express-hexa": "node scripts/verify-express-hexa-template.mjs",
    "vai:test": "node scripts/test-live.mjs",
    "visual:chat:drive": "node scripts/drive-vai-chat-visual.mjs",
    "visual:ai:compare": "node scripts/compare-ai-answers-visual.mjs",
    "e2e:audit": "node scripts/e2e-audit-suite.mjs",
    "e2e:audit:quick": "node scripts/e2e-audit-suite.mjs --quick",
    "eval:chat": "promptfoo eval -c eval/promptfoo/promptfooconfig.yaml -j 1 --no-cache",
    "eval:chat:external": "promptfoo eval -c eval/promptfoo/promptfooconfig.external.yaml -j 1 --no-cache",
    "eval:chat:view": "promptfoo view",
    "vai:trainer": "node scripts/vai-personal-trainer.mjs",
    "vai:trainer:frontend": "node scripts/vai-personal-trainer.mjs --frontend",
    "vai:trainer:strict": "node scripts/vai-personal-trainer.mjs --strict",
    "vai:trainer:adversarial": "node scripts/vai-personal-trainer.mjs --adversarial",
    "vai:trainer:json": "node scripts/vai-personal-trainer.mjs --strict --json",
    "vai:trainer:bench": "node scripts/bench-vai-trainers.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "lighthouse": "^13.1.0",
    "playwright": "^1.58.2",
    "postject": "1.0.0-alpha.6",
    "promptfoo": "^0.121.3",
    "puppeteer": "^24.37.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
