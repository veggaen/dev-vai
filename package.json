{
  "name": "vai",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "dev": "concurrently --kill-others --names runtime,desktop -c cyan,magenta \"pnpm dev:web\" \"node scripts/wait-for-runtime.mjs && pnpm dev:desktop\"",
    "dev:web": "pnpm --filter @vai/runtime dev",
    "dev:desktop": "pnpm --filter @vai/desktop dev",
    "dev:ext": "pnpm --filter @vai/extension dev",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @vai/desktop build:tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "pnpm -r --parallel typecheck",
    "db:generate": "pnpm --filter @vai/core db:generate",
    "db:migrate": "pnpm --filter @vai/core db:migrate",
    "update": "git pull && pnpm install && pnpm build",
    "nuke": "node scripts/predev.mjs && echo [VAI] All ports cleared",
    "release:dev": "git add -A && git commit && git push origin dev",
    "release:main": "git checkout main && git merge dev --no-ff && git push origin main && git checkout dev",
    "sidecar:build": "node scripts/build-sidecar.mjs",
    "vai": "node scripts/vai-server.mjs",
    "vai:start": "node scripts/vai-server.mjs start",
    "vai:stop": "node scripts/vai-server.mjs stop",
    "vai:restart": "node scripts/vai-server.mjs restart",
    "vai:status": "node scripts/vai-server.mjs status",
    "vai:test": "node scripts/test-live.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.2",
    "globals": "^17.3.0",
    "postject": "1.0.0-alpha.6",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
