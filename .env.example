# VeggaAI Environment Variables
#
# Vai works out of the box with zero config (vai:v0 n-gram engine).
# Add provider API keys to unlock real LLM capabilities.

# ── Ports ──
VAI_PORT=3006
DESKTOP_PORT=5173
VAI_HOST=127.0.0.1

# Runtime binds to loopback by default. Configure API keys before exposing it
# to a LAN or another network interface.
# VAI_API_KEYS=replace-with-a-long-random-key
# VAI_RATE_LIMIT_PER_MINUTE=60
# VAI_CAPTURE_API_KEY=replace-with-a-separate-capture-key

# ── Database ──
# SQLite (default — single user, zero config)
VAI_DB_DRIVER=sqlite
VAI_DB_PATH=./vai.db

# PostgreSQL (uncomment for multi-user scaling)
# VAI_DB_DRIVER=postgres
# DATABASE_URL=postgresql://vai:vai_secret@localhost:5432/vai
# POSTGRES_PASSWORD=vai_secret

# ── LLM Providers ──
# Set an API key to auto-enable a provider. First enabled provider becomes default.
# Priority: Anthropic > OpenAI > Google > vai:v0

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=                          # optional: for proxy/gateway

# OpenAI (GPT-4o, o3)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=                             # optional: for Azure, proxy

# Google (Gemini)
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-2.5-flash
# GOOGLE_BASE_URL=

# Local Model (Ollama, LM Studio, etc.)
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL=llama3
# When LOCAL_MODEL is set, local:<model> auto-joins the vai:v0 escalation chain
# (Master.md §12.5) — a declined / low-confidence vai:v0 turn escalates to it.

# Optional shadow advisor. It returns structured steering metadata and never
# answers directly. The UI may wait briefly so completed advice is inspectable.
# VAI_LOCAL_STEERING_ENABLED=false
# VAI_LOCAL_STEERING_MODEL=qwen2.5:7b
# VAI_LOCAL_STEERING_URL=http://localhost:11434
# VAI_LOCAL_STEERING_TIMEOUT_MS=8000
# VAI_LOCAL_STEERING_VISIBLE_WAIT_MS=1200
# VAI_LOCAL_STEERING_OUT_FILE=Temporary_files/local-steering/steering.jsonl

# Friend Review Panel — Qwen + other AIs review each draft before release and
# return a consolidated notice (concerns + suggestions). A confident "bad" verdict
# vetoes the draft; otherwise it is released. Default-off. See
# docs/capabilities/friend-review-panel.md.
# VAI_FRIEND_REVIEW_ENABLED=false
# VAI_FRIEND_REVIEW_MODELS=qwen2.5:7b,qwen2.5:3b
# VAI_FRIEND_REVIEW_URL=http://localhost:11434
# VAI_FRIEND_REVIEW_GROK=false
# VAI_FRIEND_REVIEW_TIMEOUT_MS=12000
# VAI_FRIEND_REVIEW_OUT_FILE=Temporary_files/friend-review/notices.jsonl

# ── Orchestrator: decline + post-generation verification (Master.md §8 / §12.5.3) ──
# Extra "I don't know" phrasings (localized) that should trigger escalation +
# exit verification. Semicolon or comma separated.
# VAI_DECLINE_MARKERS=det vet jeg ikke;no lo sé
# Exit gate: down-grade a confident factual claim with NO supporting evidence to
# a calibrated answer (closes the Confident-Bullshitter gap). Opt-in.
# VAI_VERIFY_REQUIRE_EVIDENCE=false
# Confidence ceiling below which a turn is calibrated rather than presented as
# certain (default 0.55).
# VAI_VERIFY_CALIBRATE_CEILING=0.55

# ── Model Selection ──
# Override the auto-detected default model
# VAI_DEFAULT_MODEL=anthropic:claude-sonnet-4-20250514

# ── Limits & Safety ──
# Maximum monthly spend in USD (0 = unlimited)
# VAI_MAX_MONTHLY_SPEND=50
# Maximum tokens per single request
# VAI_MAX_TOKENS_PER_REQUEST=16000
# Maximum concurrent requests per provider
# VAI_MAX_CONCURRENT_REQUESTS=5

# ── Web Search (optional — improves open-ended questions and unknown build requests) ──
#
# SearXNG — self-hosted meta-search (RECOMMENDED — free, unlimited, queries Google+Bing+DDG+Wikipedia simultaneously)
# Start:   docker compose -f docker/docker-compose.searxng.yml up -d
# Stop:    docker compose -f docker/docker-compose.searxng.yml down
# Health:  curl http://localhost:8080/search?q=test&format=json
# VAI_SEARXNG_URL=http://localhost:8080
#
# Brave Search API — cloud fallback, free tier 2000 req/month
# Sign up: https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=BSA...

# ── Features ──
# Enable tool calling in chat (requires a capable model)
# VAI_ENABLE_TOOL_CALLING=true
# Maximum tool-call iterations per message (safety limit)
# VAI_MAX_TOOL_ITERATIONS=10
# Enable usage/cost tracking
# VAI_ENABLE_USAGE_TRACKING=true
# Enable eval framework
# VAI_ENABLE_EVAL=false

# ── Platform Auth (VeggaAI Shell Sign-In) ──
# Default provider is WorkOS AuthKit when configured; Google OAuth is the fallback.
# Sessions: 30-day sliding TTL (VAI_SESSION_TTL_HOURS to override) — an actively
# used session never expires; only a full idle TTL logs you out.
# VAI_PLATFORM_AUTH_ENABLED=true
# VAI_PUBLIC_URL=http://localhost:3006
# VAI_APP_URL=http://localhost:5173
# VAI_SESSION_SECRET=change-me-in-production
# VAI_SESSION_TTL_HOURS=720
# VAI_OWNER_EMAIL=owner@example.com
# VAI_ADMIN_EMAILS=admin@example.com,support@example.com
#
# WorkOS AuthKit (https://dashboard.workos.com):
#   1. Create an AuthKit app → copy the API key + Client ID below.
#   2. Add this redirect URI under Redirects:
#      http://localhost:3006/api/auth/workos/callback
#   3. (Optional) Pin sign-in to one organization with WORKOS_ORGANIZATION_ID.
# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=
# WORKOS_REDIRECT_URI=http://localhost:3006/api/auth/workos/callback
# WORKOS_ORGANIZATION_ID=
#
# Google OAuth fallback (redirect URI: http://localhost:3006/api/auth/google/callback):
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_SCOPES=openid,email,profile

# ── Reown AppKit (For Generated Apps / Wallet Connect, Not Shell Login) ──
# Get credentials from https://dashboard.reown.com
# REOWN_PROJECT_ID=
# REOWN_APP_SECRET=

# ── Sandbox ──
# Max concurrent sandboxes (memory bound — each ~256-512MB)
VAI_MAX_SANDBOXES=5
VAI_SANDBOX_PORT_START=4100
VAI_SANDBOX_PORT_END=4199

# ── Docker ──
# 'true' = sandboxes in Docker containers (isolated)
# 'false' = direct process-based sandboxes (faster, less isolated)
VAI_SANDBOX_DOCKER=false

# ── TLS (uncomment for HTTPS via Traefik) ──
# ACME_EMAIL=admin@vai.ai
# VAI_DOMAIN=vai.local
