{
  "name": "@vai/core",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./browser": "./src/browser.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "tsx bench/run-bench.mts",
    "bench:conv-loop": "tsx bench/conv-loop.mts --n=1000 --turns=4",
    "bench:conv-loop:smoke": "tsx bench/conv-loop.mts --n=40 --turns=3",
    "bench:conv-loop:offline": "tsx bench/conv-loop.mts --offline --n=200 --turns=4",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@vai/constants": "workspace:*",
    "@vai/contracts": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^11.8.0",
    "drizzle-orm": "^0.38.0",
    "jsdom": "^29.1.1",
    "pdf-parse": "2.4.5",
    "puppeteer-core": "^25.1.0",
    "turndown": "^7.2.4",
    "ulid": "^2.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsdom": "^28.0.3",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
