{
  "name": "@vai/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --exclude \"./vai.db*\" --exclude \"./vai-knowledge.json*\" src/index.ts",
    "build": "tsc",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.cjs --format=cjs --external:better-sqlite3",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "@vai/api-types": "workspace:*",
    "@vai/core": "workspace:*",
    "@workos-inc/node": "^8.13.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
